# CI Dockerfile - uses official images without China mirrors
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 appuser && \
    echo "appuser ALL=(ALL) NOPASSWD: /bin/chown" >> /etc/sudoers

# Install Python dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Clone agentic-data-scientist from remote repository
RUN git clone https://gitee.com/foursking1/agentic-data-scientist.git /app/agentic-data-scientist && \
    pip install --no-cache-dir /app/agentic-data-scientist

# Copy application code
COPY backend ./backend

# Copy scientific skills
COPY scientific-skills /app/scientific-skills

# Create workspace directory with proper permissions
RUN mkdir -p /workspaces && chown -R appuser:appuser /workspaces

# Switch to non-root user
USER appuser

# Expose port
EXPOSE 8000

# Run with start.sh script
CMD ["bash", "./backend/start.sh"]
