# Test Environment Configuration
# This file is safe to commit - contains only non-sensitive test defaults

# Environment
ENVIRONMENT=testing
DEBUG=true

# Test Database (SQLite in-memory for unit tests, MySQL for E2E)
# Unit tests use in-memory SQLite automatically
DATABASE_URL=mysql+aiomysql://test:test@localhost:3306/test_sciagent

# Redis
REDIS_URL=redis://localhost:6379/1

# JWT (test only - use strong secret in production)
JWT_SECRET=test-secret-key-for-testing-only

# Workspace
WORKSPACE_BASE=/tmp/test_workspaces

# API Keys (use real keys for E2E tests with real AI calls)
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENROUTER_API_KEY=xxx
