# ===========================================
# SciAgent - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# MySQL Database Configuration
# -------------------------------------------
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_PASSWORD=your-secure-db-password
MYSQL_USER=sciagent
MYSQL_DATABASE=sciagent

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
# Generate a strong secret key for production
# openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# -------------------------------------------
# API Keys (Required for agentic-data-scientist)
# -------------------------------------------
# Anthropic API key for Claude models (used by claude_code agent)
# 可使用阿里云 DashScope 作为 Anthropic 代理
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google API key for Gemini models (optional, for native Google API)
# GOOGLE_API_KEY=xxxxx

# LiteLLM API configuration (OpenAI-compatible endpoints)
# 可使用 OpenRouter、Soholoy 或其他 OpenAI 兼容的代理
LITELLM_API_KEY=xxxxx
LITELLM_API_BASE=https://openrouter.ai/api/v1

# -------------------------------------------
# Model Configuration (agentic-data-scientist)
# -------------------------------------------
# Main model for planning and orchestration
DEFAULT_MODEL=google/gemini-2.5-pro

# Model for code review
REVIEW_MODEL=google/gemini-2.5-pro

# Model for coding tasks (claude_code agent)
CODING_MODEL=claude-sonnet-4-5-20250929

# -------------------------------------------
# Feature Flags (agentic-data-scientist)
# -------------------------------------------
# Disable structured output for OpenRouter compatibility (auto-enabled when using LITELLM_API_KEY)
# DISABLE_STRUCTURED_OUTPUT=true

# Disable network access for agents
# DISABLE_NETWORK_ACCESS=true

# -------------------------------------------
# Workspace Configuration
# -------------------------------------------
# Base directory for user workspaces
WORKSPACE_BASE=./workspaces

# -------------------------------------------
# Redis Configuration (optional for production)
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
# Backend API URL for frontend (production only)
# - Development: Auto-detected from browser hostname, leave empty
# - Production (same server): Leave empty for auto-detection
# - Production (separate server): Set to backend URL, e.g., https://api.example.com
# NEXT_PUBLIC_API_URL=https://api.example.com

# -------------------------------------------
# Docker Configuration
# -------------------------------------------
# Container names
CONTAINER_PREFIX=sciagent
